{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "cd ruflo/src/ruvocal && npm install && npm run build"
  },
  "deploy": {
    "startCommand": "cd ruflo/src/ruvocal && node build/index.js",
    "healthcheckPath": "/",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
